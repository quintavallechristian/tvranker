{
  "name": "tvranker",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@tvranker/web",
    "build": "npm run build --workspace=@tvranker/web",
    "start": "npm run start --workspace=@tvranker/web",
    "test": "npm run test --workspace=@tvranker/web",
    "lint": "npm run lint --workspace=@tvranker/web",
    "dev:mobile": "npm run start --workspace=@tvranker/mobile"
  },
  "devDependencies": {
    "expo-router": "~55.0.7"
  },
  "dependencies": {
    "expo-dev-client": "~55.0.18",
    "expo": "~55.0.8",
    "react": "19.2.0",
    "react-native": "0.83.2"
  }
}
