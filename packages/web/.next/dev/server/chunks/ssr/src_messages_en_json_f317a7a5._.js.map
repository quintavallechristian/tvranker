lder":"Search in this list...","noSearchResults":"No shows match your search","noSearchResultsHint":"Try a different search term","noFilterResults":"No shows match the selected filters","noFilterResultsHint":"Try removing some filters","analytics":"Analytics","tagDistribution":"Tag distribution","ratingDistribution":"Rating distribution","noTags":"No tags assigned yet","noRatings":"No ratings yet","shows":"shows","unrated":"Unrated","totalShows":"Total shows","ratedShows":"Rated","avgRating":"Avg. rating","analyticsEmptyHint":"Add and rate shows to see analytics","avgRatingPerTag":"Avg. rating per tag","addedOverTime":"Shows added over time","releaseDecades":"Release decade","avgRatingByDecade":"Avg. rating by decade","backToDecades":"Back to decades","noData":"Not enough data yet"},"shows":{"addShow":"Add Show","searchShows":"Search TV shows...","rating":"Rating","noRating":"Not rated","removeFromList":"Remove from list","position":"#","title":"Title","dragToReorder":"Drag to reorder"},"import":{"title":"Import Shows","chooseService":"Choose the service to import your shows from","tvtimeDesc":"JSON file (Trakt.tv / TV Time format)","malDesc":"XML export file from MyAnimeList","tvtimeTitle":"Import from TV Time","tvtimeDescription":"Upload a JSON file (Trakt.tv / TV Time format) to import your shows","malTitle":"Import from MyAnimeList","malDescription":"Upload the XML file exported from MyAnimeList","selectFileJson":"Select JSON file","selectFileXml":"Select XML file","preview":"Preview","importing":"Importing...","success":"Successfully imported {count} shows!","error":"Error importing file","invalidFormatJson":"Invalid JSON format","invalidFormatXml":"Invalid XML format","cancel":"Cancel","previewShows":"{count, plural, =0 {No shows} =1 {1 show} other {# shows}}","moviesSkipped":"{count, plural, =1 {1 movie excluded} other {# movies excluded}}","seasonsSkipped":"{count, plural, =1 {1 duplicate season merged} other {# duplicate seasons merged}}","importButton":"{count, plural, =0 {Import} =1 {Import 1 show} other {Import # shows}}"},"explore":{"title":"Explore","searchPlaceholder":"Search users or shows...","usersSection":"Users","showsSection":"Shows","showsInList":"{count, plural, =0 {No shows} =1 {1 show} other {# shows}}","noResults":"No results found","compatibility":"{score}% compatible","suggestedTitle":"Suggested for you","suggestedEmpty":"Add more shows to get personalized suggestions","suggestedLoading":"Finding shows you might like...","addedToList":"Added to your list","alreadyInList":"Already in your list","recommendedBy":"{count, plural, =1 {1 similar user} other {# similar users}}","similarUsersTitle":"People like you","similarUsersEmpty":"Add more shows to find users with similar taste","similarUsersLoading":"Finding similar profiles...","popularFallback":"Add shows to your list to get personalized suggestions. In the meantime, here are the community favorites:","addedByCount":"{count, plural, =1 {Added by 1 user} other {Added by # users}}","addToList":"Add","details":"Details"},"showDetail":{"overview":"Overview","firstAired":"First aired","rating":"TMDB Rating","inLists":"{count, plural, =1 {In 1 list} other {In # lists}}","avgRating":"Average user rating","noOverview":"No description available yet. Visit this page to load info from TMDB.","loadingInfo":"Loading show info from TMDB...","notFound":"Show not found","watchTrailer":"Watch Trailer","seasonsTitle":"Seasons","episodeCount":"{count, plural, =1 {1 episode} other {# episodes}}","streamingTitle":"Where to Watch","streamingRegion":"Availability for {region}","publicListsTitle":"Public lists with this show","analyticsTitle":"Community Analytics","ratedBy":"Rated by","ratingDistribution":"Rating distribution","noRatings":"No ratings yet","addedOverTime":"Added to lists over time","shows":"adds","users":"users","tabSeasons":"Seasons","tabTrailer":"Trailer","tabStats":"Statistics","noSeasonsData":"No season data available for this show.","noTrailer":"No trailer available for this show."},"profile":{"title":"Profile","editProfile":"Edit Profile","changeAvatar":"Change avatar","usernamePlaceholder":"Choose a username","publicLists":"Public Lists"},"settings":{"title":"Settings","language":"Language","languageDescription":"Choose the language for the app interface","english":"English","italian":"Italian"},"landing":{"hero":"Your TV shows,\nranked your way","subtitle":"Create your personal ranking, rate every show, and discover what to watch next through users with similar taste.","cta":"Get started — it's free","loginCta":"Already have an account? Sign in","features":"How it works","feature1Title":"Build your list","feature1Desc":"Search any TV show and add it to your personal list. Import from TV Time or MyAnimeList to get started quickly.","feature2Title":"Rate & rank","feature2Desc":"Rate each show from 1 to 10 with custom labels. Drag to reorder. Your list, your rules.","feature3Title":"Find your people","feature3Desc":"See how compatible you are with other users. Our algorithm compares ratings, rankings, and overlap.","feature4Title":"Smart recommendations","feature4Desc":"Collaborative filtering finds shows loved by users similar to you — the more you rate, the better it gets.","footerTagline":"Stop scrolling. Start watching."},"faq":{"title":"FAQ","subtitle":"Everything you need to know about TV Ranker","addShow":{"title":"How do I add a show to my list?","body":"Open **My List** from the sidebar. Click the **Add Show** button at the top. A dialog will appear — search for the TV show by name, then click the result to add it. The show will appear at the bottom of your list."},"importExternal":{"title":"How do I import shows from an external service?","body":"From your list, click the **Import from external services** button in the toolbar. Choose the service you want to import from:\n\n**TV Time** — Select a JSON file in Trakt.tv / TV Time format. You'll see a preview of the shows to import.\n\n**MyAnimeList** — Export your anime list as XML from MyAnimeList (Profile → Export), then upload the XML file. Completed and currently watching anime will be imported, and each imported item is automatically tagged as **anime**.\n\nIn both cases, shows already in your list will be skipped automatically."},"viewProfile":{"title":"How do I view another user's profile?","body":"Go to the **Explore** page from the sidebar and search for a username. Click on a user to visit their profile, where you can see their public list and your compatibility score."},"copyList":{"title":"How do I copy another user's list?","body":"Visit another user's list. If your own list is empty, you'll see a **Copy list** button. Clicking it will copy all their shows into your list. This option is only available when your list has no shows — it's a quick way to start from a friend's collection."},"rateShow":{"title":"How do I rate a show?","body":"In your list, each show has a rating column. Click on it to select a rating from 1 to 10. You can customize the label for each rating level in your **Profile** settings (e.g., 1 = \"Terrible\", 10 = \"Masterpiece\")."},"reorder":{"title":"How do I reorder shows in my list?","body":"Each show has a drag handle on the left side (the grip icon). Click and hold it, then drag the show up or down to your desired position. The new order is saved automatically."},"similarity":{"title":"How does the similarity algorithm work?","body":"The compatibility score (0–100%) is calculated by combining three factors:\n\n**Overlap** — How many shows you have in common, relative to the smaller list. If you share 8 out of 10 shows, the overlap is 80%.\n\n**Rating agreement** — For shows that both users have rated, how close are the ratings? A 1-point difference on a 1–10 scale is barely noticeable, while a 9-point gap means total disagreement.\n\n**Position agreement** — How similarly you rank shows in your list. If both users put a show at the top, that's a strong signal of agreement — even if one rates it 10 and the other 7 (some people are just more conservative with ratings).\n\nThe formula: `score = overlap × (50% rating closeness + 50% position closeness) × 100`\n\nShows that one or both users haven't rated still count toward overlap and position, but don't affect the rating agreement."},"recommendations":{"title":"How do show recommendations work?","body":"The **Suggested for you** section on the Explore page uses collaborative filtering — the same technique used by Netflix and Spotify.\n\nHere's how it works:\n\n**1. Find similar users** — We compare your list with all public lists using the similarity algorithm. The top 20 most similar users become your \"neighbors\".\n\n**2. Score candidate shows** — For each show your neighbors have that you don't, we calculate a score based on how similar the neighbor is to you and how highly they value that show (via rating or list position).\n\n**3. Rank and suggest** — The 10 shows with the highest combined scores are shown as recommendations.\n\nThe more shows you add and rate, the better your recommendations become. Shows that multiple similar users agree on will score higher than shows recommended by a single user."}},"rankings":{"title":"Top Rated","subtitle":"Shows ranked by average user rating across all public lists","avgRating":"avg. rating","votes":"{count, plural, =1 {1 vote} other {# votes}}","minVotesHint":"Only shows with at least 2 ratings are shown","emptyTitle":"No rankings yet","emptyDescription":"Rate shows in your public list to contribute to the community ranking"},"onboarding":{"title":"Welcome to your list!","subtitle":"Start adding shows you've watched or want to watch, or import from an external service.","addFirst":"Add a show","importExternal":"Import from external","communityFavorites":"Community favorites","addToList":"Add","details":"Details"}}